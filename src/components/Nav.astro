---
interface Props {
  page: 'home' | 'music' | 'store';
  cart?: boolean;
}

import { withBase } from '../lib/base';

const { page, cart = false } = Astro.props;
---

<nav class="nav">
  <a class="nav__brand" href={withBase('/')} aria-label="CVRNS home">
    <img src={withBase('/images/cvrns-logo.png')} alt="CVRNS" />
    <span class="nav__word">CVRNS</span>
  </a>
  <div class="nav__links">
    <a href={withBase('/')} aria-current={page === 'home' ? 'page' : undefined}>Home</a>
    <a href={withBase('/music')} aria-current={page === 'music' ? 'page' : undefined}>Music</a>
    <a href={withBase('/store')} aria-current={page === 'store' ? 'page' : undefined}>Store</a>
    <a href={withBase('/#signup')}>Newsletter</a>
    {
      cart && (
        <button type="button" class="nav__cart" aria-label="Open cart">
          Cart{' '}
          <span class="count" data-empty="true">
            0
          </span>
        </button>
      )
    }
  </div>
  <button type="button" class="nav__burger" aria-label="Open menu"
    ><span></span><span></span></button
  >
</nav>

<div class="drawer">
  <button type="button" class="drawer__close">Close</button>
  <a href={withBase('/')}>Home</a>
  <a href={withBase('/music')}>Music</a>
  <a href={withBase('/store')}>Store</a>
  <a href={withBase('/#signup')}>News</a>
  {
    cart && (
      <button type="button" class="drawer__cart nav__cart" aria-label="Open cart">
        Cart{' '}
        <span class="count" data-empty="true">
          0
        </span>
      </button>
    )
  }
</div>
