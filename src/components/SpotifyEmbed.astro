---
import { SPOTIFY_ALBUM_ID, spotifyEmbedSrc } from '../data/spotify';

interface Props {
  albumId?: string;
  title?: string;
}

const { albumId = SPOTIFY_ALBUM_ID, title = 'HERE.AFTER on Spotify' } = Astro.props;
---

<div class="embed reveal">
  <iframe
    title={title}
    data-testid="embed-iframe"
    style="border-radius:12px"
    src={spotifyEmbedSrc(albumId)}
    width="100%"
    height="352"
    frameborder="0"
    allowfullscreen
    allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
    loading="lazy"></iframe>
</div>
