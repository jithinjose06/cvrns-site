# Normalize all text to LF in the repo and working tree (matches .editorconfig
# and prevents CRLF drift that can mask encoding problems).
* text=auto eol=lf

# Treat binary assets as binary (never line-ending normalized).
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.mp4 binary
